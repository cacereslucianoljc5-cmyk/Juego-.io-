{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["@webgpu/types", "vite/client"],
    "lib": ["tsover", "DOM", "DOM.Iterable", "ES2022"],
    "strict": true,
    "noUnusedLocals": false,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true
  },
  "include": ["src"]
}
